# Pigeon Guard Configuration
# Copy this file to .env and fill in your values

# Model Configuration
PGUARD_MODEL_PATH=models/best.pt
PGUARD_CONFIDENCE_THRESHOLD=0.33
PGUARD_DEVICE=auto

# Stream Configuration
PGUARD_STREAM_URL=http://localhost:9081
PGUARD_FRAME_SKIP=5
PGUARD_RECONNECT_ATTEMPTS=3
PGUARD_RECONNECT_DELAY=5

# Detection Configuration
PGUARD_COOLDOWN_PERIOD=30
PGUARD_SAVE_DETECTIONS=true
PGUARD_DETECTION_FOLDER=detections
PGUARD_IMAGE_FORMAT=jpg
PGUARD_IMAGE_QUALITY=85

# Preprocessing Configuration
PGUARD_INPUT_WIDTH=224
PGUARD_INPUT_HEIGHT=224
PGUARD_NORMALIZE=false
PGUARD_BGR_TO_RGB=true

# Pushover Notifications
PGUARD_PUSHOVER_ENABLED=false
PGUARD_PUSHOVER_USER_KEY=
PGUARD_PUSHOVER_API_TOKEN=

# Logging Configuration
PGUARD_LOG_LEVEL=INFO
PGUARD_LOG_FILE=logs/pigeon_detection.log
PGUARD_LOG_CONSOLE=true

# Performance Configuration
PGUARD_MAX_QUEUE_SIZE=10
PGUARD_PROCESSING_THREADS=2
PGUARD_GPU_MEMORY_FRACTION=0.8

# Advanced Configuration
PGUARD_DEBUG_MODE=false
PGUARD_SAVE_ALL_FRAMES=false
PGUARD_MOTION_THRESHOLD=0.1
PGUARD_ENABLE_FACE_BLUR=false
